# auto-assign runtime
AUTO_ASSIGN_HOST=0.0.0.0
AUTO_ASSIGN_PORT=8090
AUTO_ASSIGN_DATABASE_URL=sqlite:///./data/auto_assign.sqlite3

# AssistX / Neo4j brain access through AssistX
AUTO_ASSIGN_ASSISTX_BASE_URL=http://localhost:8000
AUTO_ASSIGN_ASSISTX_TIMEOUT_SECONDS=5

# auto-router context/quota/capability access
AUTO_ASSIGN_ROUTER_BASE_URL=http://localhost:8088
AUTO_ASSIGN_ROUTER_TIMEOUT_SECONDS=5

# Safety defaults
AUTO_ASSIGN_SCHEDULER_ENABLED=false
AUTO_ASSIGN_TICK_INTERVAL_SECONDS=300
AUTO_ASSIGN_DEFAULT_LEASE_SECONDS=900
AUTO_ASSIGN_STALE_HEARTBEAT_SECONDS=120
AUTO_ASSIGN_DISPATCH_ENABLED=false
AUTO_ASSIGN_DIRECT_WORKERS_ENABLED=false
AUTO_ASSIGN_LOG_PAYLOAD_BODIES=false

# Configure event signing/auth in your private deployment environment.
# Do not commit real shared secrets or tokens.
